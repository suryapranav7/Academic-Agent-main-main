                            "Deletion",
                            "Searching",
                            "Sorting",
                            "Merging"
                        ]
                    }
                }
            ]
        },
        {
            "id": "1.2",
            "title": "Abstract Data Types (ADT)",
            "type": "section",
            "purpose": "Separation of what from how.",
            "min_teachable": true,
            "children": [
                {
                    "id": "1.2.1",
                    "title": "Definition of ADT",
                    "type": "definition",
                    "metadata": {
                        "exam_weight": "high",
                        "content_type": "definition"
                    },
                    "payload": {
                        "definition": "A set of objects and a set of operations on those objects.",
                        "key_points": [
                            "Logical description only",
                            "No implementation details"
                        ]
                    }
                },
                {
                    "id": "1.2.2",
                    "title": "ADT vs Data Structure",
                    "type": "comparison",
                    "metadata": {
                        "critical_concept": true
                    },
                    "payload": {
                        "comparison": {
                            "ADT": "Specification",
                            "Data Structure": "Implementation"
                        }
                    }
                },
                {
                    "id": "1.2.3",
                    "title": "Examples of ADT",
                    "type": "illustration",
                    "payload": {
                        "examples": [
                            "Stack ADT",
                            "Queue ADT",
                            "List ADT"
                        ]
                    }
                }
            ]
        },

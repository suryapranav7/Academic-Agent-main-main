                    "type": "concept",
                    "metadata": {
                        "difficulty": "basic",
                        "content_type": "concept"
                    },
                    "payload": {
                        "definitions": [
                            "Data: Raw facts.",
                            "Information: Processed data."
                        ],
                        "key_points": [
                            "Role of organization in turning data into information."
                        ]
                    }
                },
                {
                    "id": "1.1.2",
                    "title": "Data Types",
                    "type": "concept",
                    "metadata": {
                        "difficulty": "basic",
                        "prerequisites": [
                            "Programming Fundamentals"
                        ]
                    },
                    "payload": {
                        "classification": [
                            "Primitive",
                            "Non-primitive",
                            "User-defined"
                        ]
                    }
                },
                {
                    "id": "1.1.3",
                    "title": "Data Structures",
                    "type": "definition",
                    "metadata": {
                        "exam_weight": "medium",
                        "content_type": "definition+classification"
                    },
                    "payload": {
                        "definition": "Logical or mathematical model of a particular organization of data.",
                        "classification": [
                            "Linear vs Non-linear",
                            "Logical vs Physical"
                        ]
                    }
                },
                {
                    "id": "1.1.4",
                    "title": "Operations on Data Structures",
                    "type": "list",
                    "payload": {
                        "operations": [
